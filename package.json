{
  "name": "kutty-story",
  "version": "1.0.0",
  "private": true,
  "description": "Kutty Story - Personalized AI storybook platform",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @kutty-story/api run dev",
    "dev:web": "pnpm --filter @kutty-story/web run dev",
    "dev:admin": "pnpm --filter @kutty-story/admin run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter @kutty-story/api run build",
    "build:web": "pnpm --filter @kutty-story/web run build",
    "build:admin": "pnpm --filter @kutty-story/admin run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @kutty-story/database run generate",
    "db:migrate": "pnpm --filter @kutty-story/database run migrate:dev",
    "db:migrate:deploy": "pnpm --filter @kutty-story/database run migrate:deploy",
    "db:seed": "pnpm --filter @kutty-story/database run seed",
    "db:studio": "pnpm --filter @kutty-story/database run studio",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
