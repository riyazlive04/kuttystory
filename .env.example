# ──────────────────────────────────────────────────────────────
# Kutty Story - Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://kuttystory:kuttystory_dev@localhost:5432/kuttystory

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRATION=7d

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-secret

# ─── Razorpay (Payment Gateway) ─────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Cloudflare R2 (Object Storage) ─────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kutty-story
R2_PUBLIC_URL=https://cdn.kuttystory.com

# ─── AI Providers ────────────────────────────────────────────
# Google Gemini (primary text generation)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Anthropic Claude (fallback text generation)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Image generation provider (gemini | claude)
IMAGE_GENERATION_PROVIDER=gemini

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Kutty Story <hello@kuttystory.com>

# ─── SMS (MSG91 or similar) ─────────────────────────────────
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=KUTYST
SMS_TEMPLATE_ID=your-template-id

# ─── Shipping (Shiprocket or Delhivery) ─────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_CHANNEL_ID=your-channel-id

# ─── Frontend URLs ───────────────────────────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ─── Razorpay Frontend Key ───────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Backup (Cloudflare R2) ─────────────────────────────────
BACKUP_R2_BUCKET=kutty-story-backups
BACKUP_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-r2-access-key-for-backups
AWS_SECRET_ACCESS_KEY=your-r2-secret-key-for-backups

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
